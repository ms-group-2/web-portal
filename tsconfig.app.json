{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./out-tsc/app",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "@angular/localize",
      "node"
    ]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"]
}